
# Server
SERVER_PORT=8080
GIN_MODE=release   # release, debug, test

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=shopping_platform
DB_SSLMODE=disable

# JWT
JWT_SECRET=change_this_to_a_strong_secret_in_production

# Logging
LOG_LEVEL=info    # debug, info, warn, error, fatal, panic

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@yourapp.com

# Frontend URL
FRONTEND_URL=http://localhost:3000