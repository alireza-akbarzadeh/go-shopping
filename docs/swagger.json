                                                                    "price": {
                                                                        "type": "number",
                                                                        "format": "float64"
                                                                    },
                                                                    "product_id": {
                                                                        "type": "integer"
                                                                    },
                                                                    "quantity": {
                                                                        "type": "integer"
                                                                    },
                                                                    "total": {
                                                                        "type": "number",
                                                                        "format": "float64"
                                                                    }
                                                                }
                                                            }
                                                        },
                                                        "total": {
                                                            "type": "number",
                                                            "format": "float64"
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            ]
